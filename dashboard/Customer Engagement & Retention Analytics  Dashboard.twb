      <aliases enabled='yes' />
      <column aggregation='None' caption='Balance (bin)' datatype='integer' name='[Balance (bin)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='4' formula='[Balance]' peg='0' size='50000' />
      </column>
      <column datatype='real' name='[Balance]' role='measure' type='quantitative' />
      <column caption='Churn Rate' datatype='real' name='[Calculation_0991276482142208]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum ([Exited]) / COUNT([Customer Id])' />
      </column>
      <column caption='Retention Rate' datatype='real' name='[Calculation_0991276483178497]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1 - (SUM([Exited]) / COUNT([Customer Id]))' />
      </column>
      <column caption='Age Group ' datatype='string' name='[Calculation_0991276500803586]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Age] &lt;= 25 THEN &quot;18–25&quot;&#13;&#10;ELSEIF [Age] &lt;= 35 THEN &quot;26–35&quot;&#13;&#10;ELSEIF [Age] &lt;= 45 THEN &quot;36–45&quot;&#13;&#10;ELSEIF [Age] &lt;= 55 THEN &quot;46–55&quot;&#13;&#10;ELSEIF [Age] &lt;= 65 THEN &quot;56–65&quot;&#13;&#10;ELSE &quot;65+&quot;&#13;&#10;END' />
      </column>
      <column caption='Product Category' datatype='string' name='[Calculation_0991276723847171]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Num Of Products] = 1 THEN &quot;Single Product&quot;&#13;&#10;ELSE &quot;Multi Product&quot;&#13;&#10;END' />
      </column>
      <column caption='High Balance Inactive' datatype='string' name='[Calculation_0991276727541765]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Balance] &gt; 100000 AND [Is Active Member] = 0 THEN &quot;High Risk&quot;&#13;&#10;ELSE &quot;Others&quot;&#13;&#10;END' />
      </column>
      <column caption='High Salary Low Balance' datatype='string' name='[Calculation_0991276728332294]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Estimated Salary] &gt;= 100000 AND [Balance] &lt; 50000 THEN &quot;High Salary Low Balance&quot;&#13;&#10;ELSE &quot;Others&quot;&#13;&#10;END' />
      </column>
      <column caption='At Risk Premium' datatype='string' name='[Calculation_0991276728745991]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Is Active Member] = 0 &#13;&#10;AND [Balance] &gt;= 50000 &#13;&#10;AND [Exited] = 1 &#13;&#10;THEN &quot;At Risk Premium&quot;&#13;&#10;ELSE &quot;Others&quot;&#13;&#10;END' />
      </column>
      <column caption='Loyal Customers' datatype='string' name='[Calculation_0991276736131080]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Is Active Member] = 1 AND [Num Of Products] &gt;= 2 THEN &quot;Loyal Customers&quot;&#13;&#10;ELSE &quot;Others&quot;&#13;&#10;END' />
      </column>
      <column caption='Growth Customers' datatype='string' name='[Calculation_0991276736716809]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Is Active Member] = 1 AND [Num Of Products] = 1 THEN &quot;Growth Customers&quot;&#13;&#10;ELSE &quot;Others&quot;&#13;&#10;END' />
      </column>
      <column caption='Churn Risk' datatype='string' name='[Calculation_0991276737122314]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Is Active Member] = 0 AND [Balance] &lt; 50000 THEN &quot;Churn Risk&quot;&#13;&#10;ELSE &quot;Others&quot;&#13;&#10;END' />
      </column>
      <column caption='Premium Risk' datatype='string' name='[Calculation_0991276737462283]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Is Active Member] = 0 AND [Balance] &gt;= 50000 THEN &quot;Premium Risk&quot;&#13;&#10;ELSE &quot;Others&quot;&#13;&#10;END' />
      </column>
      <column caption='Credit Score Group' datatype='string' name='[Calculation_0991276743434252]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='STR(INT([Credit Score]/100)*100) &#13;&#10;+ &quot; - &quot; + &#13;&#10;STR(INT([Credit Score]/100)*100 + 100)' />
      </column>
      <column caption='Customer Status' datatype='string' name='[Calculation_0991276824375315]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Exited] = 1 THEN &quot;Churned&quot;&#13;&#10;ELSE &quot;Active&quot;&#13;&#10;END' />
      </column>
      <column caption='Correlation' datatype='real' name='[Calculation_0991277115408405]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CORR([Balance],[Estimated Salary])' />
      </column>
      <column caption='Active Status' datatype='string' name='[Calculation_0991277234712598]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Is Active Member] = 1 THEN &quot;Active&quot;&#13;&#10;ELSE &quot;Inactive&quot;&#13;&#10;END' />
      </column>
      <column datatype='integer' name='[Customer Id]' role='dimension' type='ordinal' />
      <column aggregation='None' caption='Estimated Salary (bin)' datatype='integer' name='[Estimated Salary (bin)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='4' formula='[Estimated Salary]' peg='0' size='50000' />
      </column>
      <column datatype='real' name='[Estimated Salary]' role='measure' type='quantitative' />
      <column datatype='integer' name='[Exited]' role='measure' type='quantitative' />
      <column datatype='string' name='[Gender]' role='dimension' type='nominal' />
      <column datatype='string' name='[Geography]' role='dimension' type='nominal' />
