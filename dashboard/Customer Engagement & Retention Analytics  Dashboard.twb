            <column caption='Retention Rate' datatype='real' name='[Calculation_0991276483178497]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='1 - (SUM([Exited]) / COUNT([Customer Id]))' />
            </column>
            <column caption='Product Category' datatype='string' name='[Calculation_0991276723847171]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Num Of Products] = 1 THEN &quot;Single Product&quot;&#13;&#10;ELSE &quot;Multi Product&quot;&#13;&#10;END' />
