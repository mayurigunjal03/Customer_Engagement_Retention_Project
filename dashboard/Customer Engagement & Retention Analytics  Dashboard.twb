    <worksheet name='Retention Rate %'>
      <table>
        <view>
          <datasources>
            <datasource caption='European_Bank (1) (European_Bank.csv)' name='federated.12weqnk1szfvdh1eveald1wi3nax' />
          </datasources>
          <datasource-dependencies datasource='federated.12weqnk1szfvdh1eveald1wi3nax'>
            <column datatype='real' name='[Balance]' role='measure' type='quantitative' />
            <column caption='Retention Rate' datatype='real' name='[Calculation_0991276483178497]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='1 - (SUM([Exited]) / COUNT([Customer Id]))' />
            </column>
            <column caption='Active Status' datatype='string' name='[Calculation_0991277234712598]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Is Active Member] = 1 THEN &quot;Active&quot;&#13;&#10;ELSE &quot;Inactive&quot;&#13;&#10;END' />
            </column>
            <column datatype='integer' name='[Customer Id]' role='dimension' type='ordinal' />
            <column datatype='integer' name='[Exited]' role='measure' type='quantitative' />
            <column datatype='string' name='[Gender]' role='dimension' type='nominal' />
            <column datatype='string' name='[Geography]' role='dimension' type='nominal' />
            <column datatype='integer' name='[Is Active Member]' role='measure' type='quantitative'>
              <aliases>
                <alias key='0' value='Inactive (0)' />
                <alias key='1' value='Active (1)' />
              </aliases>
            </column>
            <column-instance column='[Balance]' derivation='None' name='[none:Balance:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0991277234712598]' derivation='None' name='[none:Calculation_0991277234712598:nk]' pivot='key' type='nominal' />
            <column-instance column='[Gender]' derivation='None' name='[none:Gender:nk]' pivot='key' type='nominal' />
            <column-instance column='[Geography]' derivation='None' name='[none:Geography:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_0991276483178497]' derivation='User' name='[usr:Calculation_0991276483178497:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <slices>
            <column>[federated.12weqnk1szfvdh1eveald1wi3nax].[none:Geography:nk]</column>
            <column>[federated.12weqnk1szfvdh1eveald1wi3nax].[none:Gender:nk]</column>
            <column>[federated.12weqnk1szfvdh1eveald1wi3nax].[none:Calculation_0991277234712598:nk]</column>
            <column>[federated.12weqnk1szfvdh1eveald1wi3nax].[none:Balance:qk]</column>
