                        <formatted-text>
                          <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Tableau Bold' fontsize='10'>Customer Retention Analysis </run>
                          <run>Æ&#10;</run>
                          <run bold='true' fontcolor='#000000' fontname='Tableau Bold' fontsize='15'>• </run>
                          <run bold='true' fontcolor='#000000' fontname='Tableau Bold' fontsize='10'>Key Insights</run>
                          <run>Æ&#10;</run>
                          <run bold='true' fontcolor='#000000' fontname='Tableau Bold' fontsize='10'>           • Germany shows highest churn rate       </run>
                          <run>Æ&#10;</run>
                          <run bold='true' fontcolor='#000000' fontname='Tableau Bold' fontsize='10'>           • Inactive customers are more likely to churn</run>
                          <run>Æ&#10;</run>
                          <run bold='true' fontcolor='#000000' fontname='Tableau Bold' fontsize='10'>           • Customers with multiple products retain longer</run>
                          <run>Æ&#10;</run>
                          <run bold='true' fontcolor='#000000' fontname='Tableau Bold' fontsize='10'>           • High-balance inactive customers are at high risk</run>
                          <run>Æ&#10;</run>
                          <run bold='true' fontcolor='#000000' fontname='Tableau Bold' fontsize='10'>           • Active engagement strongly improves retention </run>
                          <run>Æ&#10;&#10;&#10;</run>
                        </formatted-text>
